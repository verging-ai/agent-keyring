{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentKeyring",
  "version": "0.1.0",
  "identifier": "io.agentkeyring.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AgentKeyring",
        "width": 1320,
        "height": 860,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

